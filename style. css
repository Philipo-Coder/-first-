body {
    background-color: #0d1117; /* Rangi ya giza kama GitHub */
    color: white;
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
}

.card {
    background-color: #161b22;
    padding: 30px;
    border-radius: 15px;
    border: 1px solid #30363d;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.5);
}

button {
    background-color: #238636;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
}

button:hover {
    background-color: #2ea043;
}
