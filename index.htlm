<!DOCTYPE html>
<html>
<head>
    <title>Monkey Jump Pro</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { margin: 0; overflow: hidden; background: #87CEEB; font-family: Arial, sans-serif; }
        canvas { display: block; background: linear-gradient(#1e90ff, #87ceeb); }
        #ui { position: absolute; top: 10px; left: 10px; color: white; font-size: 20px; font-weight: bold; text-shadow: 2px 2px 4px #000; }
    </style>
</head>
<body>
    <div id="ui">Score: 0</div>
    <canvas id="gameCanvas"></canvas>
    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const scoreElement = document.getElementById('ui');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        let score = 0;
        let gameActive = true;
        const monkey = { x: 50, y: canvas.height / 2, radius: 20, velocity: 0, gravity: 0.6, jump: -10 };
        const obstacles = [];
        function createObstacle() {
            const gap = 150;
            const height = Math.random() * (canvas.height - gap - 100) + 50;
            obstacles.push({ x: canvas.width, top: height, bottom: canvas.height - height - gap, width: 50 });
        }
        function update() {
            if (!gameActive) return;
            monkey.velocity += monkey.gravity;
            monkey.y += monkey.velocity;
            if (monkey.y + monkey.radius > canvas.height || monkey.y - monkey.radius < 0) gameOver();
            if (frames % 100 === 0) createObstacle();
            obstacles.forEach((obs, index) => {
                obs.x -= 3;
                if (obs.x + obs.width < 0) { obstacles.splice(index, 1); score++; scoreElement.innerText = "Score: " + score; }
                if (monkey.x + monkey.radius > obs.x && monkey.x - monkey.radius < obs.x + obs.width) {
                    if (monkey.y - monkey.radius < obs.top || monkey.y + monkey.radius > canvas.height - obs.bottom) gameOver();
                }
            });
        }
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "#A52A2A";
            ctx.beginPath();
            ctx.arc(monkey.x, monkey.y, monkey.radius, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = "#228B22";
            obstacles.forEach(obs => {
                ctx.fillRect(obs.x, 0, obs.width, obs.top);
                ctx.fillRect(obs.x, canvas.height - obs.bottom, obs.width, obs.bottom);
            });
        }
        let frames = 0;
        function loop() { update(); draw(); frames++; requestAnimationFrame(loop); }
        function gameOver() { gameActive = false; alert("Game Over! Score: " + score); location.reload(); }
        window.addEventListener('touchstart', (e) => { e.preventDefault(); monkey.velocity = monkey.jump; });
        loop();
    </script>
</body>
</html>
